{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/wapimi",
      "destination": "https://wapimi.vercel.app/"
    },
    {
      "source": "/wapimi/:path*",
      "destination": "https://wapimi.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
